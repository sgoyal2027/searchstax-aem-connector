<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0" xmlns:granite="http://www.adobe.com/jcr/granite/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    jcr:primaryType="cq:Page">
    <jcr:content
        jcr:primaryType="nt:unstructured"
        jcr:title="Indexing Report"
        sling:resourceType="granite/ui/components/coral/foundation/page">
        <head jcr:primaryType="nt:unstructured">
            <viewport
                jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/admin/page/viewport"/>
            <meta
                jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/meta"
                content="chrome=1"
                name="X-UA-Compatible"/>
            <favicon
                jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/page/favicon"/>
            <clientlibs
                jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/includeclientlibs"
                categories="[searchstaxconnector.indexingreport,searchstax.cloudconfig.touch]"/>
        </head>
        <body
            jcr:primaryType="nt:unstructured"
            sling:resourceType="granite/ui/components/coral/foundation/page/body">
            <items jcr:primaryType="nt:unstructured">
                <container
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="granite/ui/components/coral/foundation/container"
                    class="searchstax-indexing-report-page"
                    margin="{Boolean}true">
                    <items jcr:primaryType="nt:unstructured">
                        <reportTabs
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="granite/ui/components/coral/foundation/tabs"
                            granite:id="searchstax-indexing-report-tabs"
                            size="L">
                            <items jcr:primaryType="nt:unstructured">
                                <incrementalTab
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Incremental Indexing"
                                    sling:resourceType="granite/ui/components/coral/foundation/container"
                                    margin="{Boolean}false">
                                    <items jcr:primaryType="nt:unstructured">
                                        <descriptionPanel
                                            jcr:primaryType="nt:unstructured"
                                            sling:resourceType="granite/ui/components/coral/foundation/container"
                                            class="searchstax-indexing-report-description">
                                            <items jcr:primaryType="nt:unstructured">
                                                <intro
                                                    jcr:primaryType="nt:unstructured"
                                                    sling:resourceType="granite/ui/components/coral/foundation/text"
                                                    text="Review SUCCESS, FAILURE, and SKIPPED incremental indexing events from the last 24 hours."/>
                                                <filterNote
                                                    jcr:primaryType="nt:unstructured"
                                                    sling:resourceType="granite/ui/components/coral/foundation/text"
                                                    text="* Use the Action and Status filters below to narrow the results."/>
                                                <retentionNote
                                                    jcr:primaryType="nt:unstructured"
                                                    sling:resourceType="granite/ui/components/coral/foundation/text"
                                                    text="* Events are automatically removed after 24 hours."/>
                                            </items>
                                        </descriptionPanel>
                                        <filters
                                            jcr:primaryType="nt:unstructured"
                                            sling:resourceType="granite/ui/components/coral/foundation/container"
                                            class="searchstax-indexing-report-filters">
                                            <items jcr:primaryType="nt:unstructured">
                                                <actionFilter
                                                    jcr:primaryType="nt:unstructured"
                                                    sling:resourceType="granite/ui/components/coral/foundation/form/select"
                                                    emptyText="All actions"
                                                    granite:id="searchstax-indexing-report-action-filter"
                                                    name="./actionFilter">
                                                    <items jcr:primaryType="nt:unstructured">
                                                        <all
                                                            jcr:primaryType="nt:unstructured"
                                                            selected="{Boolean}true"
                                                            text="All actions"
                                                            value="ALL"/>
                                                        <activate
                                                            jcr:primaryType="nt:unstructured"
                                                            text="Publish"
                                                            value="ACTIVATE"/>
                                                        <deactivate
                                                            jcr:primaryType="nt:unstructured"
                                                            text="Unpublish"
                                                            value="DEACTIVATE"/>
                                                        <delete
                                                            jcr:primaryType="nt:unstructured"
                                                            text="Delete"
                                                            value="DELETE"/>
                                                    </items>
                                                </actionFilter>
                                                <statusFilter
                                                    jcr:primaryType="nt:unstructured"
                                                    sling:resourceType="granite/ui/components/coral/foundation/form/select"
                                                    emptyText="All statuses"
                                                    granite:id="searchstax-indexing-report-status-filter"
                                                    name="./statusFilter">
                                                    <items jcr:primaryType="nt:unstructured">
                                                        <all
                                                            jcr:primaryType="nt:unstructured"
                                                            selected="{Boolean}true"
                                                            text="All statuses"
                                                            value="ALL"/>
                                                        <success
                                                            jcr:primaryType="nt:unstructured"
                                                            text="Success"
                                                            value="SUCCESS"/>
                                                        <failure
                                                            jcr:primaryType="nt:unstructured"
                                                            text="Failure"
                                                            value="FAILURE"/>
                                                        <skipped
                                                            jcr:primaryType="nt:unstructured"
                                                            text="Skipped"
                                                            value="SKIPPED"/>
                                                    </items>
                                                </statusFilter>
                                            </items>
                                        </filters>
                                        <reportTable
                                            jcr:primaryType="nt:unstructured"
                                            sling:resourceType="granite/ui/components/coral/foundation/table"
                                            class="searchstax-indexing-report-table"
                                            granite:id="searchstax-indexing-report-table"
                                            selectionMode="none"
                                            sortMode="local">
                                            <columns jcr:primaryType="nt:unstructured">
                                                <timestamp
                                                    jcr:primaryType="nt:unstructured"
                                                    jcr:title="Time"
                                                    name="timestamp"/>
                                                <path
                                                    jcr:primaryType="nt:unstructured"
                                                    jcr:title="Path"
                                                    name="path"/>
                                                <action
                                                    jcr:primaryType="nt:unstructured"
                                                    jcr:title="Action"
                                                    name="action"/>
                                                <status
                                                    jcr:primaryType="nt:unstructured"
                                                    jcr:title="Status"
                                                    name="status"/>
                                                <message
                                                    jcr:primaryType="nt:unstructured"
                                                    jcr:title="Message"
                                                    name="message"/>
                                            </columns>
                                        </reportTable>
                                    </items>
                                </incrementalTab>
                                <fullReindexTab
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Full Reindex"
                                    sling:resourceType="granite/ui/components/coral/foundation/container"
                                    granite:id="searchstax-full-reindex-tab"
                                    margin="{Boolean}false">
                                    <items jcr:primaryType="nt:unstructured">
                                        <descriptionPanel
                                            jcr:primaryType="nt:unstructured"
                                            sling:resourceType="granite/ui/components/coral/foundation/container"
                                            class="searchstax-indexing-report-description">
                                            <items jcr:primaryType="nt:unstructured">
                                                <intro
                                                    jcr:primaryType="nt:unstructured"
                                                    sling:resourceType="granite/ui/components/coral/foundation/text"
                                                    text="Review SUCCESS and FAILURE full reindex events from the last 24 hours."/>
                                                <filterNote
                                                    jcr:primaryType="nt:unstructured"
                                                    sling:resourceType="granite/ui/components/coral/foundation/text"
                                                    text="* Use the Status filter below to narrow the results."/>
                                                <retentionNote
                                                    jcr:primaryType="nt:unstructured"
                                                    sling:resourceType="granite/ui/components/coral/foundation/text"
                                                    text="* Events are automatically removed after 24 hours."/>
                                            </items>
                                        </descriptionPanel>
                                        <runSummary
                                            jcr:primaryType="nt:unstructured"
                                            sling:resourceType="granite/ui/components/coral/foundation/container"
                                            granite:id="searchstax-full-reindex-run-summary"
                                            class="searchstax-full-reindex-run-summary"/>
                                        <filters
                                            jcr:primaryType="nt:unstructured"
                                            sling:resourceType="granite/ui/components/coral/foundation/container"
                                            class="searchstax-indexing-report-filters">
                                            <items jcr:primaryType="nt:unstructured">
                                                <statusFilter
                                                    jcr:primaryType="nt:unstructured"
                                                    sling:resourceType="granite/ui/components/coral/foundation/form/select"
                                                    emptyText="All statuses"
                                                    granite:id="searchstax-full-reindex-status-filter"
                                                    name="./fullReindexStatusFilter">
                                                    <items jcr:primaryType="nt:unstructured">
                                                        <all
                                                            jcr:primaryType="nt:unstructured"
                                                            selected="{Boolean}true"
                                                            text="All statuses"
                                                            value="ALL"/>
                                                        <success
                                                            jcr:primaryType="nt:unstructured"
                                                            text="Success"
                                                            value="SUCCESS"/>
                                                        <failure
                                                            jcr:primaryType="nt:unstructured"
                                                            text="Failure"
                                                            value="FAILURE"/>
                                                    </items>
                                                </statusFilter>
                                            </items>
                                        </filters>
                                        <reportTable
                                            jcr:primaryType="nt:unstructured"
                                            sling:resourceType="granite/ui/components/coral/foundation/table"
                                            class="searchstax-indexing-report-table"
                                            granite:id="searchstax-full-reindex-report-table"
                                            selectionMode="none"
                                            sortMode="local">
                                            <columns jcr:primaryType="nt:unstructured">
                                                <timestamp
                                                    jcr:primaryType="nt:unstructured"
                                                    jcr:title="Time"
                                                    name="timestamp"/>
                                                <path
                                                    jcr:primaryType="nt:unstructured"
                                                    jcr:title="Path"
                                                    name="path"/>
                                                <action
                                                    jcr:primaryType="nt:unstructured"
                                                    jcr:title="Action"
                                                    name="action"/>
                                                <status
                                                    jcr:primaryType="nt:unstructured"
                                                    jcr:title="Status"
                                                    name="status"/>
                                                <message
                                                    jcr:primaryType="nt:unstructured"
                                                    jcr:title="Message"
                                                    name="message"/>
                                            </columns>
                                        </reportTable>
                                    </items>
                                </fullReindexTab>
                            </items>
                        </reportTabs>
                    </items>
                </container>
            </items>
        </body>
    </jcr:content>
</jcr:root>
