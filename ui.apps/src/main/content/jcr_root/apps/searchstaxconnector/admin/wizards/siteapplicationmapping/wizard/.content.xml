<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0" xmlns:granite="http://www.adobe.com/jcr/granite/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    jcr:primaryType="cq:Page">
    <jcr:content
        jcr:primaryType="nt:unstructured"
        jcr:title="Site Application Mapping"
        sling:resourceType="granite/ui/components/coral/foundation/page">
        <head jcr:primaryType="nt:unstructured">
            <clientlibs
                jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/includeclientlibs"
                categories="[searchstax.cloudconfig.touch,searchstaxconnector.wizard]"/>
        </head>
        <body
            jcr:primaryType="nt:unstructured"
            sling:resourceType="granite/ui/components/coral/foundation/page/body">
            <items jcr:primaryType="nt:unstructured">
                <form
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="granite/ui/components/coral/foundation/form"
                    action="/bin/searchstaxconnector/wizard/site-application-mappings"
                    method="post">
                    <items jcr:primaryType="nt:unstructured">
                        <heading
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="granite/ui/components/coral/foundation/heading"
                            level="{Long}2"
                            text="Site to SearchStax Application Routing"/>
                        <description
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="granite/ui/components/coral/foundation/text"
                            text="Map AEM site content roots to SearchStax update endpoints and optional Search Profile (Model parameter). Longest matching site root wins. Leave endpoint/token blank to fall back to global API configuration."/>
                        <siteMappings
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="granite/ui/components/coral/foundation/form/multifield"
                            fieldLabel="Site mappings"
                            composite="{Boolean}true">
                            <field
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/container"
                                name="./siteMappings">
                                <items jcr:primaryType="nt:unstructured">
                                    <siteRootPath
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="granite/ui/components/coral/foundation/form/pathfield"
                                        fieldLabel="Site root path"
                                        name="./siteRootPath"
                                        rootPath="/content"
                                        required="{Boolean}true"/>
                                    <updateEndpoint
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                        fieldLabel="Update endpoint"
                                        name="./updateEndpoint"/>
                                    <updateToken
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                        fieldLabel="Update token"
                                        name="./updateToken"/>
                                    <searchProfile
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                        fieldLabel="Search profile (Model)"
                                        name="./searchProfile"/>
                                    <enabled
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="granite/ui/components/coral/foundation/form/checkbox"
                                        text="Enabled"
                                        name="./enabled"
                                        value="true"
                                        uncheckedValue="false"/>
                                </items>
                            </field>
                        </siteMappings>
                        <submit
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="granite/ui/components/coral/foundation/button"
                            text="Save"
                            type="submit"/>
                    </items>
                </form>
            </items>
        </body>
    </jcr:content>
</jcr:root>
